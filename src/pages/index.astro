---
import BaseLayout from '../layouts/BaseLayout.astro';
import IdentitySection from '../components/identity/IdentitySection';
import ProjectGrid from '../components/deployments/ProjectGrid';
import TechMatrix from '../components/techstack/TechMatrix';
import LogsPanel from '../components/systemlogs/LogsPanel';
import Roadmap from '../components/ambitions/Roadmap';
import { logs, ambitions, techStack, identity } from '../data/portfolio';
import settings from '../../public/data/settings.json';
---

<BaseLayout>
  <div class="w-full px-4 sm:px-6 lg:px-8 py-4 lg:py-6">
    <div class="flex flex-col lg:grid lg:grid-cols-[300px_1fr] gap-4 lg:gap-6 lg:items-start">

      <!-- ── LEFT: sticky identity panel ─────────────────── -->
      <div class="flex flex-col gap-3
                  lg:sticky lg:top-[60px]
                  lg:max-h-[calc(100vh-68px)]
                  lg:overflow-hidden">

        <IdentitySection
          {...identity}
          status={settings.status ?? identity.status}
          availabilityValue={settings.availabilityValue ?? identity.availabilityValue}
          cvUrl={settings.cvUrl}
          linkedinUrl={settings.linkedinUrl}
          client:load
        />

        <!-- System Logs: desktop only, fills remaining sticky space -->
        <div class="hidden lg:flex lg:flex-col lg:flex-1 lg:min-h-0">
          <div class="mb-2 pb-2 border-b border-white/[0.08] flex-shrink-0">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">System Logs</h2>
          </div>
          <div class="flex-1 min-h-0 overflow-y-auto">
            <LogsPanel logs={logs} client:load />
          </div>
        </div>

      </div>

      <!-- ── RIGHT: natural flow content ─────────────────── -->
      <div class="flex flex-col gap-6">

        <!-- Projects -->
        <section id="deployments">
          <div class="mb-3 pb-2 border-b border-white/[0.08]">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Projects</h2>
          </div>
          <ProjectGrid client:visible />
        </section>

        <!-- Technologies -->
        <section id="tech">
          <div class="mb-3 pb-2 border-b border-white/[0.08]">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Technologies & Tools</h2>
          </div>
          <TechMatrix tools={techStack} client:load />
        </section>

        <!-- Ambitions -->
        <section id="ambitions">
          <div class="mb-3 pb-2 border-b border-white/[0.08]">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Ambitions</h2>
          </div>
          <Roadmap ambitions={ambitions} client:idle />
        </section>

        <!-- System Logs: mobile only -->
        <section class="lg:hidden">
          <div class="mb-3 pb-2 border-b border-white/[0.08]">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">System Logs</h2>
          </div>
          <LogsPanel logs={logs} client:idle />
        </section>

      </div>
    </div>
  </div>
</BaseLayout>
