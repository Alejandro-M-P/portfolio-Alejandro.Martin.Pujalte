---
import BaseLayout from '../layouts/BaseLayout.astro';
import IdentitySection from '../components/identity/IdentitySection';
import ExperienceSection from '../components/experience/ExperienceSection';
import ProjectGrid from '../components/deployments/ProjectGrid';
import TechMatrix from '../components/techstack/TechMatrix';
import LogsPanel from '../components/systemlogs/LogsPanel';
import Roadmap from '../components/ambitions/Roadmap';
import { logs, ambitions, techStack, identity } from '../data/portfolio';
---

<BaseLayout>
  <div class="w-full px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-[380px_1fr] gap-6 lg:gap-8 items-start">

      <!-- LEFT: display:contents en mobile → sticky flex column en desktop -->
      <div class="contents lg:flex lg:flex-col lg:gap-5 lg:sticky lg:top-[3.5rem] lg:h-[calc(100vh-3.5rem)]">

        <div class="order-1 lg:order-none lg:flex-shrink-0">
          <IdentitySection {...identity} client:load />
        </div>

        <div class="order-5 lg:order-none lg:flex lg:flex-col lg:flex-1 lg:min-h-0" id="logs">
          <div class="mb-3.5 pb-2 border-b border-white/[0.08] relative z-[1]">
            <h2 class="text-[1.1rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">System Logs</h2>
            <p class="text-[10px] text-white/30 tracking-widest mt-0.5">Real-time activity feed — commits, merges and releases from my public repos, polled every 2h via GitHub API.</p>
          </div>
          <div class="flex-1 min-h-0">
            <LogsPanel logs={logs} client:load />
          </div>
        </div>

      </div>

      <!-- RIGHT: display:contents en mobile → flex column en desktop -->
      <div class="contents lg:flex lg:flex-col lg:gap-8">

        <section id="experience" class="order-2 lg:order-none">
          <div class="flex items-baseline gap-3 mb-3.5 pb-2 border-b border-white/[0.08] relative z-[1]">
            <h2 class="text-[1.1rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Experience</h2>
          </div>
          <div class="max-h-[420px] overflow-y-auto">
            <ExperienceSection client:load />
          </div>
        </section>

        <section id="deployments" class="order-3 lg:order-none">
          <div class="flex items-baseline gap-3 mb-3.5 pb-2 border-b border-white/[0.08] relative z-[1]">
            <h2 class="text-[1.1rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Projects</h2>
          </div>
          <div class="max-h-[520px] overflow-y-auto">
            <ProjectGrid client:visible />
          </div>
        </section>

        <section id="tech" class="order-4 lg:order-none">
          <div class="flex items-baseline gap-3 mb-3.5 pb-2 border-b border-white/[0.08] relative z-[1]">
            <h2 class="text-[1.1rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Technologies & Tools</h2>
          </div>
          <div class="max-h-[268px] overflow-y-auto">
            <TechMatrix tools={techStack} client:load />
          </div>
        </section>

        <section id="ambitions" class="order-6 lg:order-none">
          <div class="flex items-baseline gap-3 mb-3.5 pb-2 border-b border-white/[0.08] relative z-[1]">
            <h2 class="text-[1.1rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Ambitions</h2>
          </div>
          <Roadmap ambitions={ambitions} client:idle />
        </section>

      </div>
    </div>
  </div>
</BaseLayout>
