---
import BaseLayout from '../layouts/BaseLayout.astro';
import IdentitySection from '../components/identity/IdentitySection';
import ExperienceSection from '../components/experience/ExperienceSection';
import ProjectGrid from '../components/deployments/ProjectGrid';
import TechMatrix from '../components/techstack/TechMatrix';
import LogsPanel from '../components/systemlogs/LogsPanel';
import Roadmap from '../components/ambitions/Roadmap';
import { logs, ambitions, techStack, identity } from '../data/portfolio';
---

<BaseLayout>
  <!--
    Mobile:  flex-col natural, page scrolls, sections flow freely
    Desktop: two-column grid, NO page scroll, each section panel has its own scroll
  -->
  <div class="w-full px-4 sm:px-6 lg:px-8 py-4 lg:py-0 lg:h-[calc(100vh-3rem)] lg:overflow-hidden">
    <div class="flex flex-col lg:grid lg:grid-cols-[360px_1fr] lg:h-full gap-6 lg:gap-6">

      <!-- ── LEFT column ─────────────────────────────────────── -->
      <div class="flex flex-col gap-4 lg:h-full lg:overflow-hidden lg:py-4">

        <div class="lg:flex-shrink-0">
          <IdentitySection {...identity} client:load />
        </div>

        <!-- System Logs: desktop only, fills remaining height -->
        <div class="hidden lg:flex lg:flex-col lg:flex-1 lg:min-h-0" id="logs">
          <div class="mb-2 pb-2 border-b border-white/[0.08] flex-shrink-0">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">System Logs</h2>
          </div>
          <div class="flex-1 min-h-0">
            <LogsPanel logs={logs} client:load />
          </div>
        </div>

      </div>

      <!-- ── RIGHT column: flex-col, each section is a scrollable panel ─── -->
      <!--
        Desktop: sections are flex children with min-h-0, content scrolls inside.
        flex-[N] controls relative height weight.
        Mobile: sections flow naturally, page scrolls.
      -->
      <div class="flex flex-col gap-4 lg:h-full lg:py-4 lg:pr-1">

        <!-- Experience — flex-[2] → ~25% of height -->
        <section id="experience" class="flex flex-col lg:flex-[2] lg:min-h-0">
          <div class="mb-2 pb-2 border-b border-white/[0.08] flex-shrink-0">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Experience</h2>
          </div>
          <div class="lg:flex-1 lg:overflow-y-auto lg:min-h-0">
            <ExperienceSection client:load />
          </div>
        </section>

        <!-- Projects — flex-[3] → ~38% of height -->
        <section id="deployments" class="flex flex-col lg:flex-[3] lg:min-h-0">
          <div class="mb-2 pb-2 border-b border-white/[0.08] flex-shrink-0">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Projects</h2>
          </div>
          <div class="lg:flex-1 lg:overflow-y-auto lg:min-h-0">
            <ProjectGrid client:visible />
          </div>
        </section>

        <!-- Tech — flex-[2] → ~25% of height -->
        <section id="tech" class="flex flex-col lg:flex-[2] lg:min-h-0">
          <div class="mb-2 pb-2 border-b border-white/[0.08] flex-shrink-0">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Technologies & Tools</h2>
          </div>
          <div class="lg:flex-1 lg:overflow-y-auto lg:min-h-0">
            <TechMatrix tools={techStack} client:load />
          </div>
        </section>

        <!-- Ambitions: desktop only, flex-[1] → remaining space -->
        <section id="ambitions" class="hidden lg:flex lg:flex-col lg:flex-[1] lg:min-h-0 pb-2">
          <div class="mb-2 pb-2 border-b border-white/[0.08] flex-shrink-0">
            <h2 class="text-[0.85rem] font-bold text-[#f0eeec] uppercase tracking-[0.04em] font-mono">Ambitions</h2>
          </div>
          <div class="lg:flex-1 lg:overflow-y-auto lg:min-h-0">
            <Roadmap ambitions={ambitions} client:idle />
          </div>
        </section>

      </div>
    </div>
  </div>
</BaseLayout>
