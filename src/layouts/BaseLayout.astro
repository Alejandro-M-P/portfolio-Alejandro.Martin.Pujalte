---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ALEJANDRO.MARTIN.PUJALTE — Systems Engineer',
  description = 'Systems Engineer and Full-Stack Developer building high-availability infrastructure, local AI tooling, and structurally honest architectures.',
} = Astro.props;

const ogImage = '/profile.jpg';
const siteUrl = Astro.site ?? 'https://alejandro-mp.dev';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl).toString()} />
  </head>
  <body class="bg-carbono text-text-primary font-mono">

    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-carbono/80 backdrop-blur-md h-12">
      <div class="w-full px-4 sm:px-6 lg:px-8 h-full flex items-center justify-between">

        <a href="/" class="text-sm font-bold tracking-widest text-white hover:text-cobalt transition-colors duration-100 flex-shrink-0">
          ALEJANDRO.MP
        </a>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center gap-5 text-xs text-text-muted tracking-widest uppercase">
          <a href="#deployments" class="hover:text-cobalt transition-colors duration-100">Projects</a>
          <span class="text-white/20">|</span>
          <a href="#tech" class="hover:text-cobalt transition-colors duration-100">Tech</a>
          <span class="text-white/20">|</span>
          <a href="#ambitions" class="hover:text-cobalt transition-colors duration-100">Ambitions</a>
        </div>

        <div class="flex items-center gap-3">
          <div class="hidden sm:flex items-center gap-1.5 text-xs text-text-faint tracking-widest">
            <span class="w-1.5 h-1.5 bg-cobalt animate-pulse inline-block" style="border-radius:50%"></span>
            <span>ONLINE</span>
          </div>
          <span class="hidden sm:inline text-white/20">|</span>
          <a href="/admin" class="hidden md:inline text-xs text-text-faint tracking-widest hover:text-white transition-colors">ADMIN</a>

          <!-- Hamburger (mobile only) -->
          <button
            id="hamburger"
            class="md:hidden flex flex-col gap-1.5 p-1 text-text-faint hover:text-white transition-colors"
            aria-label="Menu"
          >
            <span class="block w-5 h-px bg-current transition-all duration-200" id="bar1"></span>
            <span class="block w-5 h-px bg-current transition-all duration-200" id="bar2"></span>
            <span class="block w-5 h-px bg-current transition-all duration-200" id="bar3"></span>
          </button>
        </div>

      </div>
    </nav>

    <!-- Mobile dropdown menu -->
    <div
      id="mobile-menu"
      class="fixed top-12 left-0 right-0 z-40 md:hidden border-b border-white/10 bg-carbono/95 backdrop-blur-md hidden"
    >
      <div class="flex flex-col px-6 py-4 gap-4">
        <a href="#deployments" class="mobile-link text-sm text-text-muted tracking-widest uppercase hover:text-cobalt transition-colors">Projects</a>
        <a href="#tech" class="mobile-link text-sm text-text-muted tracking-widest uppercase hover:text-cobalt transition-colors">Tech</a>
        <a href="#ambitions" class="mobile-link text-sm text-text-muted tracking-widest uppercase hover:text-cobalt transition-colors">Ambitions</a>
        <div class="border-t border-white/10 pt-3">
          <a href="/admin" class="text-xs text-text-faint tracking-widest hover:text-white transition-colors">ADMIN PANEL →</a>
        </div>
      </div>
    </div>

    <main class="pt-12">
      <slot />
    </main>

    <script>
      const hamburger = document.getElementById('hamburger');
      const menu      = document.getElementById('mobile-menu');
      const bar1      = document.getElementById('bar1');
      const bar2      = document.getElementById('bar2');
      const bar3      = document.getElementById('bar3');

      let open = false;

      function toggle() {
        open = !open;
        menu?.classList.toggle('hidden', !open);
        // Animate bars to X
        if (bar1) bar1.style.transform = open ? 'translateY(7px) rotate(45deg)' : '';
        if (bar2) bar2.style.opacity   = open ? '0' : '1';
        if (bar3) bar3.style.transform = open ? 'translateY(-7px) rotate(-45deg)' : '';
      }

      hamburger?.addEventListener('click', toggle);

      // Close on link click
      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => { if (open) toggle(); });
      });
    </script>

  </body>
</html>
